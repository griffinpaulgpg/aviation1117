generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Enquiry {
  id String @id @default(cuid())

  enquiryNumber String @unique

  fullName       String
  qualification  String
  schoolCollege  String
  selectedCourse String

  presentAddress   String @db.Text
  permanentAddress String @db.Text

  email    String
  mobile   String
  landline String?

  dateOfBirth DateTime
  gender      String

  guardianName       String
  guardianOccupation String?

  enquirySources     String[]
  otherEnquirySource String?

  referenceName String?
  remarks       String? @db.Text
  counselorName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([mobile])
  @@index([selectedCourse])
  @@index([createdAt])
}

model Course {
  id String @id @default(cuid())

  title       String
  duration    String?
  image       String
  reachUsLink String  @default("/enquiry")
  description String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([createdAt])
}

model Event {
  id String @id @default(cuid())

  title       String
  image       String?
  applyLink   String  @default("/enquiry")
  description String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([createdAt])
}

model GalleryFolder {
  id String @id @default(cuid())

  name   String         @unique
  photos GalleryPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryPhoto {
  id String @id @default(cuid())

  image    String
  caption  String?
  folderId String?
  folder   GalleryFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folderId])
  @@index([createdAt])
}

model WrittenTestimonial {
  id String @id @default(cuid())

  name        String
  position    String
  description String  @db.Text
  photo       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([createdAt])
}

model VideoTestimonial {
  id String @id @default(cuid())

  video       String
  name        String
  position    String
  description String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([createdAt])
}

model FacultyUser {
  id String @id @default(cuid())

  name         String
  email        String @unique
  passwordHash String
  role         String @default("faculty")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([createdAt])
}

model AdminUser {
  id String @id @default(cuid())

  name         String
  email        String  @unique
  passwordHash String
  isPrimary    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model ContentSeed {
  key      String   @id
  seededAt DateTime @default(now())
}
